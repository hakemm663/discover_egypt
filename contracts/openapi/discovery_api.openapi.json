{
  "openapi": "3.0.3",
  "info": {
    "title": "Discover Egypt API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.discoveregypt.com/v1"
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "searchListings",
        "parameters": [
          { "name": "query", "in": "query", "schema": { "type": "string" } },
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "city", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResponse" }
              }
            }
          }
        }
      }
    },
    "/listings": {
      "get": {
        "operationId": "listListings",
        "parameters": [
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "city", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaginatedListingResponse" }
              }
            }
          }
        }
      }
    },
    "/bookings": {
      "get": {
        "operationId": "listBookings",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BookingListResponse" }
              }
            }
          }
        }
      }
    },
    "/notifications/preferences": {
      "get": {
        "operationId": "getNotificationPreferences",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NotificationPreferences" }
              }
            }
          }
        }
      }
    },
    "/vendors": {
      "get": {
        "operationId": "listVendors",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VendorListResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Vendor": {
        "type": "object",
        "required": ["id", "name", "status"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "ListingSummary": {
        "type": "object",
        "required": ["id", "category", "title", "city", "location", "price", "rating", "reviewCount", "cancellationPolicy", "vendorName"],
        "properties": {
          "id": { "type": "string" },
          "category": { "type": "string" },
          "title": { "type": "string" },
          "city": { "type": "string" },
          "location": { "type": "string" },
          "price": { "type": "number" },
          "rating": { "type": "number" },
          "reviewCount": { "type": "integer" },
          "cancellationPolicy": { "type": "string" },
          "vendorName": { "type": "string" }
        }
      },
      "Booking": {
        "type": "object",
        "required": ["id", "status", "paymentStatus", "total", "currency"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "paymentStatus": { "type": "string" },
          "total": { "type": "number" },
          "currency": { "type": "string" }
        }
      },
      "NotificationPreferences": {
        "type": "object",
        "required": ["push", "email", "promotions"],
        "properties": {
          "push": { "type": "boolean" },
          "email": { "type": "boolean" },
          "promotions": { "type": "boolean" }
        }
      },
      "PaginatedListingResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ListingSummary" }
          },
          "page": { "type": "integer" },
          "pageSize": { "type": "integer" },
          "totalCount": { "type": "integer" }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ListingSummary" }
          },
          "page": { "type": "integer" },
          "pageSize": { "type": "integer" },
          "totalCount": { "type": "integer" }
        }
      },
      "BookingListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Booking" }
          }
        }
      },
      "VendorListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Vendor" }
          }
        }
      }
    }
  }
}
